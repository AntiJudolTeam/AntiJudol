# AntiJudol environment template. Copy to .env and tweak as needed.
# Defaults are sane — `.env` is optional unless you want to override.

# --- Shared ------------------------------------------------------------------
# `development` enables hot-reload, debug logs, and swagger; `production` does not.
ENVIRONMENT=development

# --- Proxy service (PROXY_*) -------------------------------------------------
# Bind address & port the proxy serves traffic on.
PROXY_HOST=0.0.0.0
PROXY_PORT=3000

# debug | info | warn | error. Defaults: debug in dev, info in prod.
PROXY_LOG_LEVEL=

# Filename or absolute path. When this file exists, /check returns allow for
# every request — useful to pause filtering mid-stream without a restart.
PROXY_KILL_SWITCH_PATH=.killswitch
PROXY_KILL_SWITCH_TTL_MS=2000

# algorithm: built-in pattern filter, no external dependency.
# classifier: POSTs each donation to PROXY_FILTER_URL and uses its verdict.
PROXY_FILTER_METHOD=algorithm
PROXY_FILTER_URL=http://localhost:9000
PROXY_FILTER_TIMEOUT_MS=5000

# Request limits.
PROXY_MAX_FIELD_LENGTH=4096
PROXY_JSON_BODY_LIMIT=64kb

# Feedback endpoint rate limit (per IP, per window).
PROXY_FEEDBACK_RATE_WINDOW_MS=60000
PROXY_FEEDBACK_RATE_MAX=30

# What blocked donations get rewritten to. Override to localise wording.
PROXY_BLOCK_DONATOR=Anonymous
PROXY_BLOCK_MESSAGE=Pesan ini telah diblokir oleh AntiJudol. Lakukan verifikasi lebih lanjut pada platform anda.

# Asset proxy fallback — used when no platform cookie / referer is present.
PROXY_DEFAULT_PLATFORM=saweria

# --- Filter service (FILTER_*) -----------------------------------------------
# pydantic-settings strips the prefix internally — code reads `settings.HOST`.
FILTER_HOST=127.0.0.1
FILTER_PORT=9000

# DEBUG | INFO | WARNING | ERROR | CRITICAL.
FILTER_LOG_LEVEL=INFO

# JSON list — must match Python list syntax.
FILTER_CORS_ORIGINS=["*"]

# Inference tuning.
FILTER_MODEL_BATCH_SIZE=32
FILTER_MODEL_MAX_LENGTH=512
